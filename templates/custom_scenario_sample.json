{
  "device": "Custom_Scenario_Sample",
  "vendor": "LogGen",
  "format": {
    "type": "PLAIN",
    "raw": "$TIMESTAMP $EQP_IP NOTICE attack=$ATTACK_NAME src=$SRC_IP dst=$DST_IP action=$ACTION"
  },
  "custom": [
    "$TIMESTAMP $EQP_IP NOTICE attack=SQL_Injection src=$SRC_IP dst=$DST_IP action=DENY",
    "$TIMESTAMP $EQP_IP NOTICE attack=XSS src=$SRC_IP dst=$DST_IP action=DENY",
    "$TIMESTAMP $EQP_IP NOTICE attack=Port_Scan src=$SRC_IP dst=$DST_IP action=ALERT",
    "$TIMESTAMP $EQP_IP NOTICE attack=Brute_Force src=$SRC_IP dst=$DST_IP action=BLOCK",
    "$TIMESTAMP $EQP_IP NOTICE attack=Normal_Traffic src=$SRC_IP dst=$DST_IP action=ALLOW"
  ]
}
